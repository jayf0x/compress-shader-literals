{
  "name": "compress-shader-literals",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@babel/parser": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@rollup/pluginutils": "^5.4.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^26.0.0",
    "magic-string": "^0.30.21",
    "typescript": "^6.0.3",
    "unplugin": "^3.0.0"
  },
  "scripts": {
    "build": "vite build && node scripts/compress-dist.js",
    "build:nocompress": "vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:claude": "PATH=~/.nvm/versions/node/v20.19.6/bin:$PATH npx vitest run 2>&1 | tail -8",
    "typecheck": "bunx tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "publish:npm": "bash ./scripts/publish-npm.sh",
    "rm:stalepr": "git branch -vv | grep '\\[gone\\]' | awk '{print $1}' | xargs git branch -D"
  }
}
